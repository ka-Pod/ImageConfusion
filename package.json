{
  "name": "image-confusion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "bun run --hot src/server/index.ts",
    "dev:client": "vite",
    "start": "bun run src/server/index.ts",
    "build": "vite build",
    "test": "bun test",
    "lint": "bunx tsc --noEmit"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "hono": "^4.7.0",
    "sharp": "^0.33.5",
    "unzipper": "^0.12.5",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bun": "latest",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^10.0.3",
    "typescript": "^5.7.0",
    "vite": "^8.1.4"
  }
}
